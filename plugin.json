{
  "id": "nodebb-plugin-archcyril-clearurl",
  "name": "ArchCyril Clear URL",
  "description": "Remove topic/category slugs from NodeBB URLs",
  "url":"https://github.com/chulingera2025/nodebb-plugin-archcyril-clearurl"
  "library": "./library.js",
  "staticDirs": {
    "lib": "./static/lib"
  },
  "scripts": [
    "lib/main.js"
  ],
  "hooks": [
    {
      "hook": "static:app.init",
      "method": "init"
    },
    {
      "hook": "filter:meta.getMetaTags",
      "method": "filterMetaTags"
    }
  ]
}
